#!/bin/bash

# Route natural language input to the appropriate omarchy command.
# Tier 0: Preprocessing (filler stripping + synonym normalization)
# Tier 1: Pattern matching (instant, exact phrases)
# Tier 1.5: Keyword intent scoring (instant, fuzzy)
# Tier 2: Ollama (fast, local LLM)
# Tier 3: Claude CLI (complex tasks)

set -euo pipefail

CONFIG_DIR="$HOME/.config/omarchy-cc"
CACHE_DIR="$HOME/.cache/omarchy-cc"

read_config() {
  local key="$1" default="$2"
  if [[ -f "$CONFIG_DIR/config.toml" ]]; then
    local val
    val=$(grep "^${key}\s*=" "$CONFIG_DIR/config.toml" 2>/dev/null | head -1 | sed 's/^[^=]*=\s*//' | tr -d '"' | xargs)
    [[ -n "$val" ]] && echo "$val" || echo "$default"
  else
    echo "$default"
  fi
}

OLLAMA_MODEL=$(read_config "ollama_model" "qwen2.5-coder:7b")
CLAUDE_ENABLED=$(read_config "claude_enabled" "true")

# ── Preprocessing ─────────────────────────────────────────────────────────────

normalize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' \
    | sed "s/what's/what/g; s/whats/what/g; s/it's/it/g; s/i'm/i/g; s/don't/do not/g; s/can't/cannot/g; s/won't/will not/g; s/let's/let/g; s/there's/there/g" \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed 's/[[:space:]]\+/ /g'
}

# Strip filler words and phrases. Turns "can you please make it a bit louder" → "make louder"
strip_filler() {
  local input=" $1 "

  # Multi-word filler phrases (longest first)
  for phrase in \
    "can you please" "could you please" "would you please" \
    "i would like to" "id like to" "i want to" "i need to" "i wanna" \
    "can you" "could you" "would you" "will you" \
    "go ahead and" "for me" "real quick" "right now" "as well" \
    "a little bit" "a little" "a bit" "kind of" "sort of" \
    "please" "just" "hey" "okay" "ok" "so" "actually" \
    "like" "maybe" "perhaps" "basically" "literally" "yo"; do
    input="${input// $phrase / }"
  done

  # Single-word fillers (only strip when standalone, not inside other words)
  for word in "the" "this" "that" "my" "its" "it" "me" "now" "currently" "also" "then" "and" "a" "an" "all"; do
    input="${input// $word / }"
  done

  echo "$input" | sed 's/  */ /g; s/^ //; s/ $//'
}

# Normalize synonyms to canonical forms that pattern_match understands
normalize_synonyms() {
  local input=" $1 "

  # ── Volume ──
  input="${input// louder / volume up }"
  input="${input// raise volume / volume up }"
  input="${input// increase volume / volume up }"
  input="${input// crank up / volume up }"
  input="${input// pump up / volume up }"
  input="${input// turn up volume / volume up }"
  input="${input// turn up sound / volume up }"
  input="${input// turn up audio / volume up }"
  input="${input// quieter / volume down }"
  input="${input// lower volume / volume down }"
  input="${input// decrease volume / volume down }"
  input="${input// turn down volume / volume down }"
  input="${input// turn down sound / volume down }"
  input="${input// turn down audio / volume down }"
  input="${input// silence / mute }"
  input="${input// shut up / mute }"
  input="${input// be quiet / mute }"

  # ── Brightness ──
  input="${input// dim screen / brightness down }"
  input="${input// dim display / brightness down }"
  input="${input// dim lights / brightness down }"
  input="${input// dim / brightness down }"
  input="${input// dimmer / brightness down }"
  input="${input// darker / brightness down }"
  input="${input// less bright / brightness down }"
  input="${input// turn down lights / brightness down }"
  input="${input// turn down screen / brightness down }"
  input="${input// turn down display / brightness down }"
  input="${input// brighter / brightness up }"
  input="${input// more bright / brightness up }"
  input="${input// turn up lights / brightness up }"
  input="${input// turn up screen / brightness up }"
  input="${input// turn up display / brightness up }"
  # Strip leftover "screen"/"display" after brightness replacement
  input="${input// screen / }"
  input="${input// display / }"
  input="${input// lights / }"

  # ── Window management ──
  input="${input// maximize / fullscreen }"
  input="${input// maximise / fullscreen }"
  input="${input// full screen / fullscreen }"
  input="${input// make big / fullscreen }"
  input="${input// go big / fullscreen }"
  input="${input// minimise / minimize }"
  input="${input// hide window / minimize }"

  # ── Destructive verbs → close ──
  input="${input// kill / close }"
  input="${input// terminate / close }"
  input="${input// quit / close }"
  input="${input// end / close }"

  # ── Toggle synonyms ──
  input="${input// turn on / toggle }"
  input="${input// turn off / toggle }"
  input="${input// enable / toggle }"
  input="${input// disable / toggle }"
  input="${input// activate / toggle }"
  input="${input// deactivate / toggle }"

  # ── Plurals → singular ──
  input="${input// themes / theme }"
  input="${input// fonts / font }"
  input="${input// wallpapers / wallpaper }"
  input="${input// backgrounds / background }"
  input="${input// windows / window }"
  input="${input// workspaces / workspace }"
  input="${input// packages / package }"
  input="${input// screenshots / screenshot }"

  # ── "show/display" → "list" for queries ──
  input="${input// show / list }"
  input="${input// display / list }"

  # ── Noise verbs ──
  input="${input// make / }"
  input="${input// do / }"
  input="${input// go / }"
  input="${input// put / }"
  input="${input// get / }"
  input="${input// give / }"
  input="${input// tell / }"
  input="${input// see / }"

  echo "$input" | sed 's/  */ /g; s/^ //; s/ $//'
}

# Full preprocessing pipeline
preprocess() {
  local input="$1"
  input=$(strip_filler "$input")
  input=$(normalize_synonyms "$input")
  echo "$input"
}

# ── Audio device matching ─────────────────────────────────────────────────────

audio_set_sink() {
  local keyword="$1"
  local sinks_json
  sinks_json=$(pactl -f json list sinks 2>/dev/null) || return 1

  local sink_name
  sink_name=$(echo "$sinks_json" \
    | jq -r --arg kw "$keyword" '.[] | select(.description | test($kw; "i")) | .name' \
    | head -1)

  if [[ -z "$sink_name" ]]; then
    sink_name=$(echo "$sinks_json" \
      | jq -r --arg kw "$keyword" '
        .[] | select(
          (.description | test($kw; "i")) or
          (.properties["device.alias"] // "" | test($kw; "i")) or
          (.properties["device.form_factor"] // "" | test($kw; "i")) or
          (.properties["device.icon_name"] // "" | test($kw; "i")) or
          (.properties["api.bluez5.address"] // "" | test($kw; "i")) or
          ([.ports[]?.description // ""] | any(test($kw; "i")))
        ) | .name' \
      | head -1)
  fi

  if [[ -z "$sink_name" ]]; then
    local expanded="$keyword"
    case "$keyword" in
      sony*)    expanded="(sony|wh-|wf-|mdr-|srs-)" ;;
      bose*)    expanded="(bose|qc|quietcomfort|soundlink)" ;;
      apple*)   expanded="(apple|airpod|homepod)" ;;
      airpod*)  expanded="(airpod)" ;;
      samsung*) expanded="(samsung|galaxy buds)" ;;
      jbl*)     expanded="(jbl)" ;;
      jabra*)   expanded="(jabra|elite)" ;;
      hdmi*)    expanded="(hdmi)" ;;
      usb*)     expanded="(usb)" ;;
      built*in*|internal*|laptop*) expanded="(built.in|internal|speaker)" ;;
      bluetooth*|bt) expanded="(bluez|bluetooth)" ;;
      headphone*|headset*) expanded="(headphone|headset)" ;;
      speaker*) expanded="(speaker|analog)" ;;
    esac
    if [[ "$expanded" != "$keyword" ]]; then
      sink_name=$(echo "$sinks_json" \
        | jq -r --arg kw "$expanded" '
          .[] | select(
            (.description | test($kw; "i")) or
            (.name | test($kw; "i")) or
            (.properties["device.alias"] // "" | test($kw; "i")) or
            (.properties["device.icon_name"] // "" | test($kw; "i")) or
            (.properties["device.form_factor"] // "" | test($kw; "i"))
          ) | .name' \
        | head -1)
    fi
  fi

  if [[ -n "$sink_name" ]]; then
    echo "pactl set-default-sink '$sink_name'"
    return 0
  fi
  return 1
}

extract_audio_device() {
  local input="$1"
  local result
  result=$(echo "$input" \
    | sed -E 's/^(set |switch |change |use |output )?(audio|sound|output)? ?(to |on |device )?(the |my )?//i' \
    | xargs)
  case "$result" in
    headphones|headphone|headset|earbuds|earphones|speakers|speaker) echo "$result" ; return ;;
  esac
  echo "$result" \
    | sed -E 's/ ?(output|device|speaker|speakers|headphone|headphones|headset|earbuds|earphones)$//i' \
    | xargs
}

# ── Tier 1: Pattern matching (exact, on preprocessed input) ──────────────────

pattern_match() {
  local input="$1"

  case "$input" in
    # Theme
    "set theme "*)       echo "omarchy-theme-set \"${input#set theme }\"" ;;
    "change theme to "*) echo "omarchy-theme-set \"${input#change theme to }\"" ;;
    "change theme "*)    echo "omarchy-theme-set \"${input#change theme }\"" ;;
    "switch theme"|"next theme") echo "omarchy-theme-set" ;;
    "what theme"*|"current theme"*|"which theme"*) echo "omarchy-theme-current" ;;
    "list theme"*|"show theme"*) echo "omarchy-theme-list" ;;
    "install theme"*)    echo "omarchy-theme-install" ;;
    "remove theme"*)     echo "omarchy-theme-remove" ;;

    # Wallpaper
    "next wallpaper"|"change wallpaper"|"new wallpaper"|"next background"|"change background"|"new background"|"next bg")
      echo "omarchy-theme-bg-next" ;;

    # Font
    "set font "*)        echo "omarchy-font-set \"${input#set font }\"" ;;
    "change font "*)     echo "omarchy-font-set \"${input#change font }\"" ;;
    "what font"*|"current font"*|"which font"*) echo "omarchy-font-current" ;;
    "list font"*|"show font"*) echo "omarchy-font-list" ;;

    # Volume
    "volume up")   echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+" ;;
    "volume down") echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" ;;
    "mute"|"toggle mute") echo "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" ;;
    "unmute")      echo "wpctl set-mute @DEFAULT_AUDIO_SINK@ 0" ;;

    # Audio device
    "switch audio"|"audio switch"|"next audio"|"change output"|"next output")
      echo "omarchy-cmd-audio-switch" ;;
    "switch to next "*)
      echo "omarchy-cmd-audio-switch" ;;
    "audio"*"settings"|"open audio"|"sound settings"|"audio controls")
      echo "omarchy-launch-audio" ;;
    "set audio "* | "set output "* | "set sound "* | \
    "switch audio to "* | "switch output to "* | \
    "change audio to "* | "change output to "* | \
    "use "*" headphones" | "use "*" speaker"* | "use "*" headset" | \
    "audio to "* | "output to "* | "sound to "* | \
    "audio output "* | "sound output "*)
      local device
      device=$(extract_audio_device "$input")
      if [[ -n "$device" ]]; then
        local cmd
        if cmd=$(audio_set_sink "$device"); then
          echo "$cmd"
        else
          echo "echo 'No audio device matching \"$device\" found. Available:' && pactl -f json list sinks | jq -r '.[].description'"
        fi
      else
        echo "omarchy-cmd-audio-switch"
      fi
      ;;

    # Brightness
    "brightness up")     echo "brightnessctl set 10%+" ;;
    "brightness down")   echo "brightnessctl set 10%-" ;;
    "brightness "*)
      local val="${input#brightness }"
      val="${val%\%}"
      echo "brightnessctl set ${val}%" ;;

    # Nightlight
    "toggle nightlight"|"nightlight"|"night light"|"blue light"*)
      echo "omarchy-toggle-nightlight" ;;

    # Screenshot / Recording
    "screenshot"|"take screenshot"|"snap"|"capture screen"|"capture")
      echo "omarchy-cmd-screenshot smart" ;;
    "screenshot area"|"screenshot region"|"snip")
      echo "omarchy-cmd-screenshot smart" ;;
    "screenshot full"|"full screenshot")
      echo "omarchy-cmd-screenshot smart clipboard" ;;
    "screen record"*|"screenrecord"*|"record screen"*|"record")
      echo "omarchy-cmd-screenrecord" ;;

    # Launch apps
    "launch browser"|"open browser") echo "omarchy-launch-browser" ;;
    "launch editor"|"open editor")   echo "omarchy-launch-editor" ;;
    "launch terminal"|"open terminal"|"new terminal")
      echo "uwsm-app -- xdg-terminal-exec" ;;
    "launch file"*|"open file"*|"files")
      echo "uwsm-app -- nautilus --new-window" ;;
    "launch "*)
      local app="${input#launch }"
      echo "omarchy-launch-or-focus \"$app\" || hyprctl dispatch exec \"$app\"" ;;
    "open "*)
      local app="${input#open }"
      echo "omarchy-launch-or-focus \"$app\" || hyprctl dispatch exec \"$app\"" ;;

    # Window management
    "fullscreen"|"toggle fullscreen") echo "hyprctl dispatch fullscreen" ;;
    "float"|"floating"|"toggle float"*|"toggle floating")
      echo "hyprctl dispatch togglefloating" ;;
    "center window"|"center") echo "hyprctl dispatch centerwindow" ;;
    "close"|"close window") echo "hyprctl dispatch killactive" ;;
    "minimize"|"minimise") echo "hyprctl dispatch movetospecial" ;;
    "workspace "*)
      local ws="${input#workspace }"
      echo "hyprctl dispatch workspace $ws" ;;
    "move to workspace "*)
      local ws="${input#move to workspace }"
      echo "hyprctl dispatch movetoworkspace $ws" ;;
    "move window to "*)
      local ws="${input#move window to }"
      echo "hyprctl dispatch movetoworkspace $ws" ;;

    # System
    "lock"|"lock screen")   echo "omarchy-lock-screen" ;;
    "screensaver")          echo "omarchy-launch-screensaver force" ;;
    "toggle waybar"|"toggle bar"|"hide bar"|"show bar")
      echo "omarchy-toggle-waybar" ;;
    "toggle gaps"|"gaps")   echo "omarchy-hyprland-workspace-toggle-gaps" ;;
    "close all"*"window"*)  echo "omarchy-hyprland-window-close-all" ;;
    "pop window"|"pop out"|"pin window")
      echo "omarchy-hyprland-window-pop" ;;

    # Restart services
    "restart waybar")       echo "omarchy-restart-waybar" ;;
    "restart pipewire"|"restart audio") echo "omarchy-restart-pipewire" ;;
    "restart wifi")         echo "omarchy-restart-wifi" ;;
    "restart bluetooth")    echo "omarchy-restart-bluetooth" ;;
    "restart walker")       echo "omarchy-restart-walker" ;;
    "restart "*)
      local svc="${input#restart }"
      echo "omarchy-restart-$svc" ;;

    # Info
    "what time"*|"time")    echo "date '+%H:%M'" ;;
    "what date"*|"date"|"today"*) echo "date '+%A, %B %d %Y'" ;;
    "uptime")               echo "uptime -p" ;;
    "battery"|"battery life"|"battery remaining") echo "omarchy-battery-remaining" ;;
    "version"|"omarchy version") echo "omarchy-version" ;;
    "about")                echo "omarchy-launch-about" ;;
    "system info"|"sysinfo"|"specs") echo "fastfetch" ;;
    "storage"|"disk"|"disk usage"|"disk space"|"free space"|"how much space"*)
      echo "df -h --output=source,size,used,avail,pcent -x tmpfs -x devtmpfs -x efivarfs" ;;

    # Power
    "reboot"|"restart computer"|"restart system") echo "omarchy-cmd-reboot" ;;
    "shutdown"|"power off"|"shut down") echo "omarchy-cmd-shutdown" ;;
    "suspend"|"sleep")      echo "systemctl suspend" ;;

    # Connectivity
    "bluetooth"*"setting"*|"bluetooth") echo "omarchy-launch-bluetooth" ;;
    "wifi"*"setting"*|"wifi") echo "omarchy-launch-wifi" ;;

    # Packages
    "install package"*|"install pkg"*) echo "omarchy-pkg-install" ;;
    "remove package"*|"remove pkg"*|"uninstall"*) echo "omarchy-pkg-remove" ;;
    "update"|"update system"|"update omarchy") echo "omarchy-update" ;;

    # Menu
    "menu")                 echo "omarchy-menu" ;;
    "settings"|"preferences"|"setup") echo "omarchy-menu setup" ;;
    "keybindings"|"key bindings"|"shortcuts") echo "omarchy-menu-keybindings" ;;

    # Sharing
    "share"|"share clipboard") echo "omarchy-cmd-share clipboard" ;;
    "share file")           echo "omarchy-cmd-share file" ;;

    # Dictation
    "dictation status"|"voxtype status") echo "omarchy-voxtype-status" ;;

    *) return 1 ;;
  esac
}

# ── Tier 1.5: Keyword intent scoring (fuzzy, order-independent) ──────────────
# Each intent has required keywords (all must match) and optional boost keywords.
# Highest scoring intent wins. This catches everything preprocessing + patterns miss.

keyword_match() {
  local input="$1"
  local -a words=($input)
  local best_intent="" best_score=0

  # Helper: check if input contains a word
  has() { [[ " $input " == *" $1 "* ]]; }

  # Helper: count how many of the given words appear in input
  count_matches() {
    local n=0
    for w in "$@"; do has "$w" && ((n++)); done
    echo "$n"
  }

  # ── Volume ──
  if has "volume" && has "up"; then
    echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"; return 0
  fi
  if has "volume" && has "down"; then
    echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; return 0
  fi
  # "louder" / "quieter" should already be normalized, but catch stragglers
  if has "louder" || has "raise" && has "volume"; then
    echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"; return 0
  fi
  if has "quieter" || has "lower" && has "volume"; then
    echo "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; return 0
  fi
  if has "mute" || has "silence"; then
    echo "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; return 0
  fi
  if has "unmute"; then
    echo "wpctl set-mute @DEFAULT_AUDIO_SINK@ 0"; return 0
  fi

  # ── Audio device ──
  if has "audio" || has "output" || has "sound" || has "headphone" || has "headphones" || has "speaker" || has "speakers" || has "headset"; then
    # Check for "cycle/next" intent BEFORE trying device match
    if has "next" || has "cycle"; then
      echo "omarchy-cmd-audio-switch"; return 0
    fi
    if has "setting" || has "settings" || has "control" || has "controls"; then
      echo "omarchy-launch-audio"; return 0
    fi
    # Try to find a specific device name
    local remaining="$input"
    remaining="${remaining//audio/}"; remaining="${remaining//output/}"; remaining="${remaining//sound/}"
    remaining="${remaining//switch/}"; remaining="${remaining//set/}"; remaining="${remaining//change/}"; remaining="${remaining//use/}"
    remaining="${remaining//to/}"; remaining="${remaining//on/}"
    remaining=$(echo "$remaining" | sed 's/  */ /g; s/^ //; s/ $//')
    if [[ -n "$remaining" ]]; then
      local cmd
      if cmd=$(audio_set_sink "$remaining"); then
        echo "$cmd"; return 0
      fi
    fi
    # Fallback: generic audio switch if "switch" was in original input
    if has "switch"; then
      echo "omarchy-cmd-audio-switch"; return 0
    fi
  fi

  # ── Brightness ──
  if has "brightness" && has "up" || has "brighter"; then
    echo "brightnessctl set 10%+"; return 0
  fi
  if has "brightness" && has "down" || has "dim" || has "dimmer"; then
    echo "brightnessctl set 10%-"; return 0
  fi
  if has "brightness"; then
    # Try to extract a percentage
    local pct
    pct=$(echo "$input" | grep -oE '[0-9]+' | head -1)
    if [[ -n "$pct" ]]; then
      echo "brightnessctl set ${pct}%"; return 0
    fi
  fi

  # ── Window management ──
  if has "fullscreen" || has "maximize"; then
    echo "hyprctl dispatch fullscreen"; return 0
  fi
  if has "float" || has "floating"; then
    echo "hyprctl dispatch togglefloating"; return 0
  fi
  if has "center" && has "window"; then
    echo "hyprctl dispatch centerwindow"; return 0
  fi
  if has "minimize"; then
    echo "hyprctl dispatch movetospecial"; return 0
  fi
  if has "close" && (has "window" || has "app" || has "application"); then
    echo "hyprctl dispatch killactive"; return 0
  fi
  if has "close" && has "all"; then
    echo "omarchy-hyprland-window-close-all"; return 0
  fi

  # ── Workspace ──
  if has "workspace"; then
    local num
    num=$(echo "$input" | grep -oE '[0-9]+' | head -1)
    if [[ -n "$num" ]]; then
      if has "move"; then
        echo "hyprctl dispatch movetoworkspace $num"; return 0
      fi
      echo "hyprctl dispatch workspace $num"; return 0
    fi
  fi

  # ── Theme ──
  if has "theme"; then
    if has "list" || has "show" || has "all"; then
      echo "omarchy-theme-list"; return 0
    fi
    if has "current" || has "what" || has "which"; then
      echo "omarchy-theme-current"; return 0
    fi
    if has "set" || has "change" || has "switch"; then
      # Extract theme name: everything after theme-related keywords
      local name="$input"
      name="${name//theme/}"; name="${name//set/}"; name="${name//change/}"; name="${name//switch/}"; name="${name//to/}"
      name=$(echo "$name" | sed 's/  */ /g; s/^ //; s/ $//')
      if [[ -n "$name" ]]; then
        echo "omarchy-theme-set \"$name\""; return 0
      fi
      echo "omarchy-theme-set"; return 0
    fi
    if has "install"; then echo "omarchy-theme-install"; return 0; fi
    if has "remove" || has "delete"; then echo "omarchy-theme-remove"; return 0; fi
    if has "next"; then echo "omarchy-theme-set"; return 0; fi
  fi

  # ── Font ──
  if has "font"; then
    if has "list" || has "show" || has "all"; then echo "omarchy-font-list"; return 0; fi
    if has "current" || has "what" || has "which"; then echo "omarchy-font-current"; return 0; fi
    if has "set" || has "change"; then
      local name="$input"
      name="${name//font/}"; name="${name//set/}"; name="${name//change/}"; name="${name//to/}"
      name=$(echo "$name" | sed 's/  */ /g; s/^ //; s/ $//')
      if [[ -n "$name" ]]; then echo "omarchy-font-set \"$name\""; return 0; fi
    fi
  fi

  # ── Wallpaper ──
  if has "wallpaper" || has "background" || has "bg"; then
    if has "next" || has "change" || has "new" || has "cycle"; then
      echo "omarchy-theme-bg-next"; return 0
    fi
    echo "omarchy-theme-bg-next"; return 0
  fi

  # ── Nightlight ──
  if has "nightlight"; then
    echo "omarchy-toggle-nightlight"; return 0
  fi
  if has "night" && has "light"; then
    echo "omarchy-toggle-nightlight"; return 0
  fi
  if has "blue" && has "light"; then
    echo "omarchy-toggle-nightlight"; return 0
  fi
  if has "blue" && has "filter"; then
    echo "omarchy-toggle-nightlight"; return 0
  fi

  # ── Screenshot ──
  if has "screenshot" || has "screencapture" || has "capture" && has "screen" || has "snap" && has "screen"; then
    echo "omarchy-cmd-screenshot smart"; return 0
  fi

  # ── Screen recording ──
  if has "record" && has "screen" || has "screenrecord" || has "recording"; then
    echo "omarchy-cmd-screenrecord"; return 0
  fi

  # ── Time/Date ──
  if has "time" && (has "what" || has "show" || has "tell" || has "display"); then
    echo "date '+%H:%M'"; return 0
  fi
  if has "date" && (has "what" || has "show" || has "tell" || has "display"); then
    echo "date '+%A, %B %d %Y'"; return 0
  fi

  # ── Storage/Disk ──
  if has "storage" || has "disk" || has "space" && (has "free" || has "left" || has "available" || has "how" || has "much"); then
    echo "df -h --output=source,size,used,avail,pcent -x tmpfs -x devtmpfs -x efivarfs"; return 0
  fi

  # ── System info ──
  if has "battery"; then echo "omarchy-battery-remaining"; return 0; fi
  if has "uptime"; then echo "uptime -p"; return 0; fi
  if has "version"; then echo "omarchy-version"; return 0; fi
  if has "specs" || has "sysinfo" || has "system" && has "info"; then echo "fastfetch"; return 0; fi

  # ── Toggles ──
  if has "waybar" || has "bar" && has "top" || has "status" && has "bar"; then
    if has "toggle" || has "hide" || has "show"; then
      echo "omarchy-toggle-waybar"; return 0
    fi
    if has "restart"; then echo "omarchy-restart-waybar"; return 0; fi
  fi
  if has "gaps" && (has "toggle" || ! has "restart"); then
    echo "omarchy-hyprland-workspace-toggle-gaps"; return 0
  fi
  if has "screensaver"; then
    if has "toggle"; then echo "omarchy-toggle-screensaver"; return 0; fi
    echo "omarchy-launch-screensaver force"; return 0
  fi

  # ── Lock ──
  if has "lock" && (has "screen" || ${#words[@]} -le 2); then
    echo "omarchy-lock-screen"; return 0
  fi

  # ── Power ──
  if has "reboot" || has "restart" && (has "computer" || has "system" || has "pc"); then
    echo "omarchy-cmd-reboot"; return 0
  fi
  if has "shutdown" || has "shut" && has "down" || has "power" && has "off"; then
    echo "omarchy-cmd-shutdown"; return 0
  fi
  if has "suspend" || has "sleep" && ! has "toggle"; then
    echo "systemctl suspend"; return 0
  fi

  # ── Restart services ──
  if has "restart"; then
    has "audio" || has "pipewire" && { echo "omarchy-restart-pipewire"; return 0; }
    has "wifi" || has "network" && { echo "omarchy-restart-wifi"; return 0; }
    has "bluetooth" && { echo "omarchy-restart-bluetooth"; return 0; }
    has "walker" || has "launcher" && { echo "omarchy-restart-walker"; return 0; }
    has "waybar" || has "bar" && { echo "omarchy-restart-waybar"; return 0; }
  fi

  # ── Connectivity ──
  if has "bluetooth"; then echo "omarchy-launch-bluetooth"; return 0; fi
  if has "wifi" || has "wireless"; then echo "omarchy-launch-wifi"; return 0; fi

  # ── Packages ──
  if has "install" && (has "package" || has "pkg" || has "app"); then
    echo "omarchy-pkg-install"; return 0
  fi
  if has "remove" && (has "package" || has "pkg"); then
    echo "omarchy-pkg-remove"; return 0
  fi
  if has "update" && (has "system" || has "omarchy" || ${#words[@]} -le 2); then
    echo "omarchy-update"; return 0
  fi

  # ── Launch apps (catch-all for "open/launch/start <app>") ──
  if has "launch" || has "open" || has "start" || has "run"; then
    has "browser" && { echo "omarchy-launch-browser"; return 0; }
    has "editor" && { echo "omarchy-launch-editor"; return 0; }
    has "terminal" && { echo "uwsm-app -- xdg-terminal-exec"; return 0; }
    has "file" || has "files" && { echo "uwsm-app -- nautilus --new-window"; return 0; }

    # Generic: extract app name
    local app="$input"
    app="${app//launch/}"; app="${app//open/}"; app="${app//start/}"; app="${app//run/}"
    app=$(echo "$app" | sed 's/  */ /g; s/^ //; s/ $//')
    if [[ -n "$app" ]]; then
      echo "omarchy-launch-or-focus \"$app\" || hyprctl dispatch exec \"$app\""
      return 0
    fi
  fi

  # ── Menu ──
  if has "menu"; then echo "omarchy-menu"; return 0; fi
  if has "settings" || has "preferences"; then echo "omarchy-menu setup"; return 0; fi
  if has "keybinding" || has "keybindings" || has "shortcuts" || has "hotkeys"; then
    echo "omarchy-menu-keybindings"; return 0
  fi

  # ── Share ──
  if has "share"; then
    has "file" && { echo "omarchy-cmd-share file"; return 0; }
    echo "omarchy-cmd-share clipboard"; return 0
  fi

  return 1
}

# ── Context gathering for LLM tiers ──────────────────────────────────────────

gather_context() {
  local ctx=""
  ctx+="Current theme: $(omarchy-theme-current 2>/dev/null || echo unknown)"$'\n'

  local sink_name sink_desc
  sink_name=$(pactl get-default-sink 2>/dev/null || echo "")
  if [[ -n "$sink_name" ]]; then
    sink_desc=$(pactl -f json list sinks 2>/dev/null | jq -r --arg n "$sink_name" '.[] | select(.name == $n) | .description' 2>/dev/null || echo "$sink_name")
    ctx+="Current audio output: $sink_desc"$'\n'
  fi

  local active_class active_title
  active_class=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // empty' 2>/dev/null || echo "")
  active_title=$(hyprctl activewindow -j 2>/dev/null | jq -r '.title // empty' 2>/dev/null || echo "")
  [[ -n "$active_class" ]] && ctx+="Active window: $active_class — $active_title"$'\n'

  local ws_id
  ws_id=$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty' 2>/dev/null || echo "")
  [[ -n "$ws_id" ]] && ctx+="Current workspace: $ws_id"$'\n'

  local mon_count
  mon_count=$(hyprctl monitors -j 2>/dev/null | jq 'length' 2>/dev/null || echo "1")
  ctx+="Monitors: $mon_count"$'\n'

  ctx+="Current font: $(omarchy-font-current 2>/dev/null || echo unknown)"$'\n'
  echo "$ctx"
}

# ── Ollama system prompt ─────────────────────────────────────────────────────

build_ollama_prompt() {
  local context="$1"
  cat <<SYSPROMPT
You are a command router for Omarchy, a Linux desktop environment on Arch Linux with Hyprland.
Your job: convert natural language requests into a SINGLE shell command.

CURRENT SYSTEM STATE:
$context
RULES:
- Output ONLY the shell command. Nothing else. No explanation, no markdown, no backticks.
- If you need to chain commands, use && or ;
- Prefer omarchy-* commands when they exist for the task.
- For unknown requests, use standard Linux commands.
- If you truly cannot determine a command, output: echo "I don't know how to do that"
- Use the current system state to give context-aware answers.

AVAILABLE OMARCHY COMMANDS:
omarchy-theme-set <name> — Set the desktop theme
omarchy-theme-current — Show current theme name
omarchy-theme-list — List available themes
omarchy-theme-bg-next — Cycle to next wallpaper
omarchy-theme-install — Install a new theme
omarchy-theme-remove — Remove a theme
omarchy-font-set <name> — Set the system monospace font
omarchy-font-current — Show current font
omarchy-font-list — List available fonts
omarchy-toggle-nightlight — Toggle blue light filter
omarchy-toggle-screensaver — Toggle screensaver
omarchy-toggle-idle — Toggle idle lock
omarchy-toggle-waybar — Toggle the top bar
omarchy-toggle-suspend — Toggle suspend capability
omarchy-lock-screen — Lock the screen
omarchy-launch-browser — Launch default browser
omarchy-launch-editor — Launch default editor
omarchy-launch-audio — Launch audio controls
omarchy-launch-bluetooth — Launch bluetooth settings
omarchy-launch-about — Show system info
omarchy-launch-or-focus <app> — Launch or focus an app
omarchy-launch-webapp <url> — Launch a URL as a web app
omarchy-launch-screensaver force — Start the screensaver
omarchy-cmd-audio-switch — Cycle to next audio output device
omarchy-cmd-screenshot smart — Take a screenshot
omarchy-cmd-screenrecord — Record the screen
omarchy-cmd-share clipboard|file|folder — Share via LocalSend
omarchy-cmd-reboot — Reboot the system
omarchy-cmd-shutdown — Shutdown the system
omarchy-battery-remaining — Show battery percentage
omarchy-version — Show Omarchy version
omarchy-pkg-install — Interactive package installer
omarchy-pkg-remove — Interactive package remover
omarchy-pkg-add <pkg> — Install a specific package
omarchy-pkg-drop <pkg> — Remove a specific package
omarchy-update — Update Omarchy and system
omarchy-restart-waybar — Restart the top bar
omarchy-restart-pipewire — Restart audio system
omarchy-restart-wifi — Restart Wi-Fi
omarchy-restart-bluetooth — Restart Bluetooth
omarchy-restart-walker — Restart app launcher
omarchy-menu — Open the Omarchy menu
omarchy-menu-keybindings — Show keybinding reference
omarchy-hyprland-workspace-toggle-gaps — Toggle window gaps
omarchy-hyprland-window-close-all — Close all windows
omarchy-hyprland-window-pop — Pop/pin current window
omarchy-debug — Show debug info
omarchy-install-dev-env <lang> — Install dev environment
omarchy-refresh-hyprland — Reset Hyprland config to defaults
omarchy-refresh-waybar — Reset Waybar config to defaults

AUDIO DEVICE SELECTION:
pactl set-default-sink '<sink_name>' — Set a specific audio output
pactl -f json list sinks | jq -r '.[] | select(.description | test("<keyword>"; "i")) | .name' — Find sink by name

OTHER COMMANDS:
hyprctl dispatch exec/workspace/movetoworkspace/fullscreen/togglefloating/killactive
wpctl set-volume @DEFAULT_AUDIO_SINK@ <N%+/->
wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
brightnessctl set <N%+/->
systemctl suspend
date, uptime -p, fastfetch
SYSPROMPT
}

# ── Tier 2: Ollama ───────────────────────────────────────────────────────────

ollama_route() {
  local input="$1" context="$2"
  command -v ollama &>/dev/null || return 1

  local system_prompt
  system_prompt=$(build_ollama_prompt "$context")

  local result
  result=$(ollama run "$OLLAMA_MODEL" --nowordwrap "$system_prompt

User request: $input" 2>/dev/null | tr -d '`' | sed '/^$/d' | head -5)

  [[ -z "$result" ]] && return 1

  result=$(echo "$result" | sed 's/^```[a-z]*//;s/^```$//' | sed '/^$/d')
  local first_line
  first_line=$(echo "$result" | head -1)

  if echo "$first_line" | grep -qE '^(omarchy-|hyprctl|wpctl|pactl|brightnessctl|systemctl|date|uptime|fastfetch|echo|cat|ls|df|free|uname|whoami|hostname|sudo|pacman|yay|notify-send|uwsm-app|setsid|kill|pkill|pidof|xdg-|walker|/|~|ps |top |htop|sensors|ip |ss |curl |wget )'; then
    echo "$result"; return 0
  fi
  if echo "$first_line" | grep -qE '^[a-zA-Z0-9_/.-]+ '; then
    echo "$result"; return 0
  fi
  return 1
}

# ── Tier 3: Claude CLI ───────────────────────────────────────────────────────

claude_route() {
  local input="$1" context="$2"
  [[ "$CLAUDE_ENABLED" != "true" ]] && return 1
  command -v claude &>/dev/null || return 1

  local system_prompt
  system_prompt=$(build_ollama_prompt "$context")
  system_prompt="$system_prompt

ADDITIONAL INSTRUCTIONS FOR COMPLEX TASKS:
- You can output multi-line scripts for complex tasks
- Chain commands with && for sequential execution
- Use bash constructs like for loops, if statements, etc.
- For file creation tasks, use cat with heredocs
- Always output executable shell commands, never explanations"

  local result
  result=$(claude -p --output-format text --system-prompt "$system_prompt" "$input" 2>/dev/null)
  [[ -z "$result" ]] && return 1
  echo "$result"
}

needs_claude() {
  local input="$1"
  case "$input" in
    *"write a script"*|*"create a script"*|*"make a script"*) return 0 ;;
    *"write a"*|*"create a"*|*"generate"*) return 0 ;;
    *"use claude"*|*"think harder"*|*"think about"*) return 0 ;;
    *"explain"*|*"help me"*|*"how do i"*|*"how to"*) return 0 ;;
    *) return 1 ;;
  esac
}

# ── Main routing ─────────────────────────────────────────────────────────────

main() {
  if [[ $# -eq 0 ]]; then
    echo "Usage: omarchy-cc-route <natural language input>" >&2
    exit 1
  fi

  local raw_input="$*"
  local input
  input=$(normalize "$raw_input")

  [[ -z "$input" ]] && exit 1

  # Pass through raw commands
  if echo "$input" | grep -qE '^(omarchy-|hyprctl |wpctl |pactl |brightnessctl |systemctl |sudo )'; then
    echo "$raw_input"
    exit 0
  fi

  # Preprocess: strip filler, normalize synonyms
  local processed
  processed=$(preprocess "$input")

  # Tier 1: Exact pattern match (on preprocessed input)
  local result
  if result=$(pattern_match "$processed"); then
    echo "$result"
    exit 0
  fi

  # Also try pattern match on raw normalized input (for "open X", "launch X" etc.)
  if result=$(pattern_match "$input"); then
    echo "$result"
    exit 0
  fi

  # Tier 1.5: Keyword intent scoring (on preprocessed input, then raw)
  if result=$(keyword_match "$processed"); then
    echo "$result"
    exit 0
  fi
  if result=$(keyword_match "$input"); then
    echo "$result"
    exit 0
  fi

  # Gather context for LLM tiers
  local context
  context=$(gather_context 2>/dev/null || echo "")

  # Check if this needs Claude
  if needs_claude "$input"; then
    if result=$(claude_route "$raw_input" "$context"); then
      echo "TIER:claude"
      echo "$result"
      exit 0
    fi
  fi

  # Tier 2: Ollama
  if result=$(ollama_route "$raw_input" "$context"); then
    echo "TIER:ollama"
    echo "$result"
    exit 0
  fi

  # Tier 3: Claude fallback
  if result=$(claude_route "$raw_input" "$context"); then
    echo "TIER:claude"
    echo "$result"
    exit 0
  fi

  echo "TIER:none"
  echo "echo \"Sorry, I couldn't figure out how to do that.\""
  exit 0
}

main "$@"
