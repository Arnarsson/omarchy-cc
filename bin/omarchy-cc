#!/bin/bash

# Omarchy Command Center — Voice+text command center for your desktop.
# Press Super+I to toggle. Type or speak natural language commands.

set -uo pipefail

CONFIG_DIR="$HOME/.config/omarchy-cc"
CACHE_DIR="$HOME/.cache/omarchy-cc"
HISTORY_FILE="$CACHE_DIR/history"
LOG_FILE="$CACHE_DIR/cc.log"
LAST_ACTION_FILE="$CACHE_DIR/last-action"
LAST_OUTPUT_FILE="$CACHE_DIR/last-output"
SESSION_LOG="$CACHE_DIR/session-output"

mkdir -p "$CACHE_DIR"
touch "$HISTORY_FILE"
: > "$SESSION_LOG"

# Load config (single-pass parser)
eval "$(omarchy-cc-config)"
HISTORY_SIZE="${CC_HISTORY_SIZE:-100}"

# Add to history
add_history() {
  local entry="$1"
  [[ -z "$entry" ]] && return
  local last
  last=$(tail -1 "$HISTORY_FILE" 2>/dev/null || true)
  [[ "$last" == "$entry" ]] && return
  echo "$entry" >> "$HISTORY_FILE"
  local count
  count=$(wc -l < "$HISTORY_FILE")
  if [[ $count -gt $HISTORY_SIZE ]]; then
    local excess=$((count - HISTORY_SIZE))
    tail -n +"$((excess + 1))" "$HISTORY_FILE" > "$HISTORY_FILE.tmp" && mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
  fi
}

# Show recent history
show_history() {
  if [[ -s "$HISTORY_FILE" ]]; then
    local count
    count=$(wc -l < "$HISTORY_FILE")
    local show=$((count < 5 ? count : 5))
    gum style --foreground 8 --faint "recent"
    tail -n "$show" "$HISTORY_FILE" | tac | while IFS= read -r line; do
      gum style --foreground 8 --faint "  › $line"
    done
    echo ""
  fi
}

# Copy entire pane content to clipboard
copy_pane() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux capture-pane -p -S - | wl-copy 2>/dev/null
  else
    # Fallback: try script/terminal capture, or use saved output
    if [[ -s "$SESSION_LOG" ]]; then
      wl-copy < "$SESSION_LOG" 2>/dev/null
    elif [[ -s "$LAST_OUTPUT_FILE" ]]; then
      wl-copy < "$LAST_OUTPUT_FILE" 2>/dev/null
    else
      gum style --foreground 8 "Nothing to copy."
      return
    fi
  fi
  gum style --foreground 2 "  ✓ Copied to clipboard"
}

# Show the header
show_header() {
  gum style \
    --foreground 4 --bold \
    --border rounded \
    --border-foreground 8 \
    --padding "0 2" \
    --margin "0 0 1 0" \
    "⌘  Command Center"
}

# Load last action state
load_last_action() {
  if [[ -f "$LAST_ACTION_FILE" ]]; then
    source "$LAST_ACTION_FILE" 2>/dev/null || true
  fi
}

# Generate a human-readable description of what the command does
describe_action() {
  local cmd="$1"
  case "$cmd" in
    omarchy-theme-set\ *)    echo "Setting theme to ${cmd#omarchy-theme-set }" ;;
    omarchy-theme-set)       echo "Picking a theme" ;;
    omarchy-theme-current*)  echo "Checking current theme" ;;
    omarchy-theme-list*)     echo "Listing themes" ;;
    omarchy-theme-bg-next*)  echo "Switching wallpaper" ;;
    omarchy-theme-next*)     echo "Cycling theme" ;;
    omarchy-theme-install*)  echo "Installing theme" ;;
    omarchy-theme-remove*)   echo "Removing theme" ;;
    omarchy-font-set\ *)     echo "Setting font to ${cmd#omarchy-font-set }" ;;
    omarchy-font-current*)   echo "Checking current font" ;;
    omarchy-font-list*)      echo "Listing fonts" ;;
    "wpctl set-volume"*+*)   echo "Turning volume up" ;;
    "wpctl set-volume"*-*)   echo "Turning volume down" ;;
    "wpctl set-mute"*)       echo "Toggling mute" ;;
    "pactl set-default-sink"*) echo "Switching audio output" ;;
    omarchy-cmd-audio-switch*) echo "Cycling audio output" ;;
    omarchy-launch-audio*)   echo "Opening audio settings" ;;
    "brightnessctl set"*+*)  echo "Turning brightness up" ;;
    "brightnessctl set"*-*)  echo "Turning brightness down" ;;
    "brightnessctl set"*)    echo "Setting brightness" ;;
    omarchy-toggle-nightlight*) echo "Toggling night light" ;;
    omarchy-toggle-waybar*)  echo "Toggling status bar" ;;
    omarchy-toggle-*)        echo "Toggling ${cmd#omarchy-toggle-}" ;;
    omarchy-cmd-screenshot*) echo "Taking screenshot" ;;
    omarchy-cmd-screenrecord*) echo "Recording screen" ;;
    omarchy-cmd-share*)      echo "Sharing" ;;
    omarchy-launch-browser*) echo "Opening browser" ;;
    omarchy-launch-editor*)  echo "Opening editor" ;;
    omarchy-launch-or-focus*) echo "Launching app" ;;
    omarchy-launch-*)        echo "Opening ${cmd#omarchy-launch-}" ;;
    "hyprctl dispatch fullscreen"*) echo "Toggling fullscreen" ;;
    "hyprctl dispatch togglefloating"*) echo "Toggling floating" ;;
    "hyprctl dispatch centerwindow"*) echo "Centering window" ;;
    "hyprctl dispatch killactive"*) echo "Closing window" ;;
    "hyprctl dispatch movetospecial"*) echo "Minimizing window" ;;
    "hyprctl dispatch workspace "*)
      echo "Switching to workspace ${cmd#hyprctl dispatch workspace }" ;;
    "hyprctl dispatch movetoworkspace "*)
      echo "Moving to workspace ${cmd#hyprctl dispatch movetoworkspace }" ;;
    "hyprctl dispatch exec"*) echo "Launching app" ;;
    omarchy-lock-screen*)    echo "Locking screen" ;;
    omarchy-launch-screensaver*) echo "Starting screensaver" ;;
    omarchy-restart-*)       echo "Restarting ${cmd#omarchy-restart-}" ;;
    omarchy-update*)         echo "Updating system" ;;
    omarchy-pkg-install*|omarchy-pkg-add*) echo "Installing package" ;;
    omarchy-pkg-remove*|omarchy-pkg-drop*) echo "Removing package" ;;
    omarchy-cmd-reboot*)     echo "Rebooting" ;;
    omarchy-cmd-shutdown*)   echo "Shutting down" ;;
    "systemctl suspend"*)    echo "Suspending" ;;
    "date '+%H:%M'"*)       echo "Checking time" ;;
    "date"*)                 echo "Checking date" ;;
    "uptime"*)               echo "Checking uptime" ;;
    omarchy-battery-*)       echo "Checking battery" ;;
    omarchy-version*)        echo "Checking version" ;;
    "fastfetch"*)            echo "Showing system info" ;;
    "df -h"*)                echo "Checking storage" ;;
    omarchy-menu-keybindings*) echo "Showing keybindings" ;;
    omarchy-menu*)           echo "Opening menu" ;;
    omarchy-hyprland-workspace-toggle-gaps*) echo "Toggling gaps" ;;
    omarchy-hyprland-window-close-all*) echo "Closing all windows" ;;
    omarchy-hyprland-window-pop*) echo "Popping window" ;;
    "uwsm-app -- nautilus"*) echo "Opening file manager" ;;
    "uwsm-app -- xdg-terminal-exec"*) echo "Opening terminal" ;;
    omarchy-launch-bluetooth*) echo "Opening bluetooth settings" ;;
    omarchy-launch-wifi*)    echo "Opening wifi settings" ;;
    omarchy-voxtype-status*) echo "Checking dictation status" ;;
    omarchy-cc-tmux*)        echo "Managing tmux sessions" ;;
    *) echo "" ;;
  esac
}

# Process a single command input
process_input() {
  local input="$1"

  # Route the input
  local route_output
  route_output=$(omarchy-cc-route "$input" 2>/dev/null) || true

  if [[ -z "$route_output" ]]; then
    gum style --foreground 1 "✗ Couldn't understand that."
    return 1
  fi

  # Parse tier information
  local tier="pattern"
  local command="$route_output"

  if [[ "$route_output" == TIER:* ]]; then
    tier=$(echo "$route_output" | head -1 | sed 's/^TIER://')
    command=$(echo "$route_output" | tail -n +2)
  fi

  # Show compact feedback: → Description ─ command
  local description
  description=$(describe_action "$command")

  if [[ -n "$description" ]]; then
    gum style --foreground 2 --bold "→ $description" --foreground 8 " ─ $command"
  else
    gum style --foreground 8 --faint "  $command"
  fi

  # For Claude tier with multi-line output, show and confirm
  if [[ "$tier" == "claude" ]]; then
    local line_count
    line_count=$(echo "$command" | wc -l)
    if [[ $line_count -gt 3 ]]; then
      echo "$command" | gum style --foreground 7 --border rounded --padding "1 2"
      echo ""
      if ! gum confirm "Execute this?"; then
        gum style --foreground 3 "Cancelled."
        return 1
      fi
    fi
  fi

  # Execute via the safety gate (pass tier and input for logging)
  # Must quote $command so pipes/|| aren't interpreted by this shell
  omarchy-cc-exec -t "$tier" -i "$input" "$command"

  add_history "$input"
}

# Handle meta-commands: undo, again, last
handle_meta() {
  local input="$1"

  case "$input" in
    undo|"undo that"|"go back"|"revert")
      load_last_action
      if [[ -n "${UNDO:-}" ]]; then
        gum style --foreground 3 "Undoing: $UNDO"
        echo ""
        omarchy-cc-exec -t undo -i "undo" $UNDO
        return 0
      else
        gum style --foreground 8 "Nothing to undo."
        return 0
      fi
      ;;
    again|"do that again"|"repeat"|"run again"|"same")
      load_last_action
      if [[ -n "${COMMAND:-}" ]]; then
        gum style --foreground 8 --faint "Repeating: $COMMAND"
        echo ""
        omarchy-cc-exec -t repeat -i "${INPUT:-again}" $COMMAND
        add_history "${INPUT:-again}"
        return 0
      else
        gum style --foreground 8 "Nothing to repeat."
        return 0
      fi
      ;;
    last|"last command"|"what did i do"|"what was that")
      load_last_action
      if [[ -n "${COMMAND:-}" ]]; then
        gum style --foreground 7 "Last: ${INPUT:-unknown}"
        gum style --foreground 8 --faint "  → $COMMAND"
        [[ -n "${UNDO:-}" ]] && gum style --foreground 8 --faint "  ↩ undo: $UNDO"
        return 0
      else
        gum style --foreground 8 "No previous command."
        return 0
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

# Fuzzy search history with gum filter
search_history() {
  if [[ ! -s "$HISTORY_FILE" ]]; then
    gum style --foreground 8 "No history yet."
    return
  fi

  local selected
  selected=$(tac "$HISTORY_FILE" | gum filter --placeholder "Search history..." --height 15 --width 60) || return

  if [[ -n "$selected" ]]; then
    echo ""
    process_input "$selected"
  fi
}

# Show log entries
show_log() {
  local count="${1:-20}"
  if [[ ! -s "$LOG_FILE" ]]; then
    gum style --foreground 8 "No log entries yet."
    return
  fi

  gum style --foreground 4 --bold "Activity Log"
  echo ""

  tail -n "$count" "$LOG_FILE" | while IFS= read -r line; do
    local ts tier input cmd exit_code ms
    ts=$(echo "$line" | jq -r '.ts' 2>/dev/null) || continue
    tier=$(echo "$line" | jq -r '.tier' 2>/dev/null)
    input=$(echo "$line" | jq -r '.input' 2>/dev/null)
    cmd=$(echo "$line" | jq -r '.cmd' 2>/dev/null)
    exit_code=$(echo "$line" | jq -r '.exit' 2>/dev/null)
    ms=$(echo "$line" | jq -r '.ms' 2>/dev/null)

    local status_icon="✓" color=2
    [[ "$exit_code" != "0" ]] && status_icon="✗" && color=1

    local tier_color=8
    case "$tier" in
      pattern) tier_color=2 ;;
      ollama)  tier_color=3 ;;
      claude)  tier_color=5 ;;
    esac

    local ts_short="${ts#*T}"
    if [[ "$input" != "$cmd" ]]; then
      printf "  %s  %s  %-7s  %s\n" "$ts_short" "$status_icon" "$tier" "$input"
      printf "                       → %s  (%sms)\n" "$cmd" "$ms"
    else
      printf "  %s  %s  %-7s  %s  (%sms)\n" "$ts_short" "$status_icon" "$tier" "$input" "$ms"
    fi
  done
}

# Main TUI loop
main() {
  # Handle single-command mode (for piping or scripting)
  if [[ $# -gt 0 ]]; then
    process_input "$*"
    exit $?
  fi

  clear
  show_header
  show_history

  # Main loop
  while true; do
    local input
    input=$(gum input \
      --placeholder "Type a command (or: copy, undo, help)" \
      --width 60 \
      --char-limit 500 \
      --prompt "> " \
      --prompt.foreground 4 \
    ) || true

    # Handle exit
    if [[ -z "$input" || "$input" == "q" || "$input" == "exit" || "$input" == "quit" ]]; then
      exit 0
    fi

    # Handle clear
    if [[ "$input" == "clear" ]]; then
      clear
      show_header
      continue
    fi

    # Handle fuzzy history search
    if [[ "$input" == "history" || "$input" == "/" ]]; then
      search_history
      echo ""
      continue
    fi

    # Handle log viewing
    if [[ "$input" == "log" || "$input" == "logs" ]]; then
      show_log 20
      echo ""
      continue
    fi

    if [[ "$input" == "log all" ]]; then
      show_log 9999
      echo ""
      continue
    fi

    # Handle copy
    if [[ "$input" == "copy" || "$input" == "cp" || "$input" == "copy all" || "$input" == "cp all" ]]; then
      copy_pane
      echo ""
      continue
    fi

    # Handle help
    if [[ "$input" == "help" || "$input" == "?" ]]; then
      gum style --foreground 4 --bold "Commands"
      echo ""
      gum style --foreground 7 "  Type natural language commands like:"
      gum style --foreground 8 "    set theme tokyo night       set audio to sony"
      gum style --foreground 8 "    next wallpaper              volume up"
      gum style --foreground 8 "    launch browser              screenshot"
      echo ""
      gum style --foreground 7 "  Meta:"
      gum style --foreground 8 "    undo       — reverse the last action"
      gum style --foreground 8 "    again      — repeat the last command"
      gum style --foreground 8 "    last       — show what you just ran"
      echo ""
      gum style --foreground 7 "  Special:"
      gum style --foreground 8 "    copy       — copy terminal content to clipboard"
      gum style --foreground 8 "    history /  — fuzzy search past commands"
      gum style --foreground 8 "    log        — show recent activity log"
      gum style --foreground 8 "    clear      — clear the screen"
      gum style --foreground 8 "    ? help     — show this help"
      gum style --foreground 8 "    q exit     — close Command Center"
      echo ""
      gum style --foreground 7 "  Voice: Hold Alt+X to dictate (if voxtype installed)"
      echo ""
      continue
    fi

    echo ""

    # Try meta-commands first (undo, again, last)
    if handle_meta "$input" 2>/dev/null; then
      echo ""
      continue
    fi

    process_input "$input"
    echo ""
  done
}

main "$@"
