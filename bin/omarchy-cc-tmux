#!/bin/bash

# Tmux session manager for Command Center.
# Usage:
#   omarchy-cc-tmux           — list sessions with CPU/MEM
#   omarchy-cc-tmux kill <N>  — kill session N
#   omarchy-cc-tmux kill-detached — kill all detached sessions
#   omarchy-cc-tmux monitor   — launch live curses monitor

set -uo pipefail

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed."
  exit 1
fi

# Get CPU% and MEM% for all processes in a tmux session
session_resources() {
  local session="$1"
  local pids
  pids=$(tmux list-panes -t "$session" -F '#{pane_pid}' 2>/dev/null) || { echo "0.0 0.0"; return; }

  local total_cpu=0 total_mem=0
  for pid in $pids; do
    [[ -z "$pid" ]] && continue
    local stats
    stats=$(ps -p "$pid" --ppid "$pid" -o %cpu=,%mem= --no-headers 2>/dev/null) || continue
    while read -r cpu mem; do
      [[ -z "$cpu" ]] && continue
      total_cpu=$(awk "BEGIN{print $total_cpu + $cpu}")
      total_mem=$(awk "BEGIN{print $total_mem + $mem}")
    done <<< "$stats"
  done

  printf "%.1f %.1f" "$total_cpu" "$total_mem"
}

format_duration() {
  local elapsed="$1"
  if [[ $elapsed -lt 60 ]]; then
    echo "${elapsed}s"
  elif [[ $elapsed -lt 3600 ]]; then
    echo "$((elapsed / 60))m"
  elif [[ $elapsed -lt 86400 ]]; then
    local hours=$((elapsed / 3600))
    local mins=$(( (elapsed % 3600) / 60 ))
    echo "${hours}h ${mins}m"
  else
    local days=$((elapsed / 86400))
    local hours=$(( (elapsed % 86400) / 3600 ))
    echo "${days}d ${hours}h"
  fi
}

action="${1:-list}"
target="${2:-}"

case "$action" in
  list)
    sessions=$(tmux list-sessions -F '#{session_name}|#{session_created}|#{session_windows}|#{session_attached}' 2>/dev/null)

    if [[ -z "$sessions" ]]; then
      echo "No active tmux sessions."
      exit 0
    fi

    now=$(date +%s)

    printf "  %-12s %4s %6s %6s  %-10s  %s\n" "SESSION" "WIN" "CPU%" "MEM%" "UPTIME" "STATUS"
    printf "  %-12s %4s %6s %6s  %-10s  %s\n" "────────────" "───" "─────" "─────" "──────────" "────────"

    while IFS='|' read -r name created windows attached; do
      elapsed=$((now - created))
      age=$(format_duration "$elapsed")

      read -r cpu mem <<< "$(session_resources "$name")"

      status="detached"
      [[ "$attached" == "1" ]] && status="attached"

      printf "  %-12s %4s %5s%% %5s%%  %-10s  %s\n" "$name" "$windows" "$cpu" "$mem" "$age" "$status"
    done <<< "$sessions"

    echo ""
    echo "  kill <name>  to kill a session  ·  kill detached  to kill all detached"
    ;;

  kill)
    if [[ "$target" == "detached" || "$target" == "all-detached" ]]; then
      killed=0
      while IFS='|' read -r name created windows attached; do
        if [[ "$attached" != "1" ]]; then
          tmux kill-session -t "$name" 2>/dev/null && ((killed++))
        fi
      done <<< "$(tmux list-sessions -F '#{session_name}|#{session_created}|#{session_windows}|#{session_attached}' 2>/dev/null)"

      if [[ $killed -gt 0 ]]; then
        echo "Killed $killed detached session(s)."
      else
        echo "No detached sessions to kill."
      fi
    elif [[ -n "$target" ]]; then
      if tmux has-session -t "$target" 2>/dev/null; then
        tmux kill-session -t "$target" 2>/dev/null
        echo "Killed session '$target'."
      else
        echo "Session '$target' not found."
      fi
    else
      echo "Usage: kill <session-name> or kill detached"
    fi
    ;;

  monitor)
    # Launch the live curses monitor in a new terminal window
    monitor_script="$(dirname "$0")/omarchy-cc-tmux-monitor"
    if [[ -x "$monitor_script" ]]; then
      setsid uwsm-app -- xdg-terminal-exec --title="tmux monitor" -e "$monitor_script" &>/dev/null &
      disown
      echo "Opened tmux monitor."
    else
      echo "Live monitor not available. Showing list instead."
      exec "$0" list
    fi
    ;;

  *)
    echo "Unknown action: $action"
    exit 1
    ;;
esac
