#!/bin/bash

# Interactive tmux session manager for Command Center.
# Lists active sessions with age, allows killing selected ones.

set -uo pipefail

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed."
  exit 1
fi

sessions=$(tmux list-sessions -F '#{session_name}|#{session_created}|#{session_windows}|#{session_attached}' 2>/dev/null)

if [[ -z "$sessions" ]]; then
  echo "No active tmux sessions."
  exit 0
fi

now=$(date +%s)

# Build display list
display=()
names=()
while IFS='|' read -r name created windows attached; do
  elapsed=$((now - created))

  # Human-readable duration
  if [[ $elapsed -lt 60 ]]; then
    age="${elapsed}s"
  elif [[ $elapsed -lt 3600 ]]; then
    age="$((elapsed / 60))m"
  elif [[ $elapsed -lt 86400 ]]; then
    hours=$((elapsed / 3600))
    mins=$(( (elapsed % 3600) / 60 ))
    age="${hours}h ${mins}m"
  else
    days=$((elapsed / 86400))
    hours=$(( (elapsed % 86400) / 3600 ))
    age="${days}d ${hours}h"
  fi

  status=""
  [[ "$attached" == "1" ]] && status=" (attached)"

  display+=("$name  ·  ${windows} windows  ·  ${age}${status}")
  names+=("$name")
done <<< "$sessions"

# Show sessions
echo ""
gum style --foreground 4 --bold "Active tmux sessions"
echo ""

for line in "${display[@]}"; do
  echo "  $line"
done

echo ""

# Ask what to do
action=$(gum choose "Kill a session" "Kill all detached" "Done" --header "Action?" 2>/dev/null) || exit 0

case "$action" in
  "Kill a session")
    selected=$(printf '%s\n' "${display[@]}" | gum filter --placeholder "Select session to kill..." 2>/dev/null) || exit 0
    # Find the session name from the display string
    target="${selected%%  ·*}"
    if gum confirm "Kill session '$target'?"; then
      tmux kill-session -t "$target" 2>/dev/null
      gum style --foreground 2 "✓ Killed session '$target'"
    else
      gum style --foreground 3 "Cancelled."
    fi
    ;;
  "Kill all detached")
    detached=()
    while IFS='|' read -r name created windows attached; do
      [[ "$attached" != "1" ]] && detached+=("$name")
    done <<< "$sessions"

    if [[ ${#detached[@]} -eq 0 ]]; then
      gum style --foreground 8 "No detached sessions."
    else
      if gum confirm "Kill ${#detached[@]} detached session(s)?"; then
        for name in "${detached[@]}"; do
          tmux kill-session -t "$name" 2>/dev/null
        done
        gum style --foreground 2 "✓ Killed ${#detached[@]} detached session(s)"
      else
        gum style --foreground 3 "Cancelled."
      fi
    fi
    ;;
  "Done")
    ;;
esac
