#!/bin/bash

# Tmux session manager for Command Center.
# Usage:
#   omarchy-cc-tmux           — list sessions
#   omarchy-cc-tmux kill <N>  — kill session N
#   omarchy-cc-tmux kill-detached — kill all detached sessions

set -uo pipefail

if ! command -v tmux &>/dev/null; then
  echo "tmux is not installed."
  exit 1
fi

action="${1:-list}"
target="${2:-}"

case "$action" in
  list)
    sessions=$(tmux list-sessions -F '#{session_name}|#{session_created}|#{session_windows}|#{session_attached}' 2>/dev/null)

    if [[ -z "$sessions" ]]; then
      echo "No active tmux sessions."
      exit 0
    fi

    now=$(date +%s)

    printf "  %-10s %-10s %-12s %s\n" "SESSION" "WINDOWS" "UPTIME" "STATUS"
    printf "  %-10s %-10s %-12s %s\n" "-------" "-------" "------" "------"

    while IFS='|' read -r name created windows attached; do
      elapsed=$((now - created))

      if [[ $elapsed -lt 60 ]]; then
        age="${elapsed}s"
      elif [[ $elapsed -lt 3600 ]]; then
        age="$((elapsed / 60))m"
      elif [[ $elapsed -lt 86400 ]]; then
        hours=$((elapsed / 3600))
        mins=$(( (elapsed % 3600) / 60 ))
        age="${hours}h ${mins}m"
      else
        days=$((elapsed / 86400))
        hours=$(( (elapsed % 86400) / 3600 ))
        age="${days}d ${hours}h"
      fi

      status="detached"
      [[ "$attached" == "1" ]] && status="attached"

      printf "  %-10s %-10s %-12s %s\n" "$name" "$windows" "$age" "$status"
    done <<< "$sessions"

    echo ""
    echo "  kill <name>  to kill a session  ·  kill detached  to kill all detached"
    ;;

  kill)
    if [[ "$target" == "detached" || "$target" == "all-detached" ]]; then
      killed=0
      while IFS='|' read -r name created windows attached; do
        if [[ "$attached" != "1" ]]; then
          tmux kill-session -t "$name" 2>/dev/null && ((killed++))
        fi
      done <<< "$(tmux list-sessions -F '#{session_name}|#{session_created}|#{session_windows}|#{session_attached}' 2>/dev/null)"

      if [[ $killed -gt 0 ]]; then
        echo "Killed $killed detached session(s)."
      else
        echo "No detached sessions to kill."
      fi
    elif [[ -n "$target" ]]; then
      if tmux has-session -t "$target" 2>/dev/null; then
        tmux kill-session -t "$target" 2>/dev/null
        echo "Killed session '$target'."
      else
        echo "Session '$target' not found."
      fi
    else
      echo "Usage: kill <session-name> or kill detached"
    fi
    ;;

  *)
    echo "Unknown action: $action"
    exit 1
    ;;
esac
